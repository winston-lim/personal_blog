{
  "name": "nextjs-notion-starter-kit",
  "version": "2.0.0",
  "private": true,
  "description": "The perfect starter kit for building beautiful websites with Next.js and Notion.",
  "author": "Travis Fischer <travis@transitivebullsh.it>",
  "repository": "transitive-bullshit/nextjs-notion-starter-kit",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "deploy": "vercel deploy",
    "deps": "run-s deps:*",
    "deps:update": "[ -z $GITHUB_ACTIONS ] && yarn add notion-client notion-types notion-utils react-notion-x || echo 'Skipping deps:update on CI'",
    "deps:link": "[ -z $GITHUB_ACTIONS ] && yarn link notion-client notion-types notion-utils react-notion-x || echo 'Skipping deps:link on CI'",
    "analyze": "cross-env ANALYZE=true next build",
    "analyze:server": "cross-env BUNDLE_ANALYZE=server next build",
    "analyze:browser": "cross-env BUNDLE_ANALYZE=browser next build",
    "test": "run-p test:*",
    "test:lint": "eslint '**/*.{ts,tsx}'",
    "test:prettier": "prettier '**/*.{js,jsx,ts,tsx}' --check"
  },
  "dependencies": {
    "@fisch0920/use-dark-mode": "^2.4.0",
    "@keyvhq/core": "^1.6.9",
    "@keyvhq/redis": "^1.6.10",
    "@react-icons/all-files": "^4.1.0",
    "@vercel/analytics": "^1.5.0",
    "@vercel/og": "^0.6.5",
    "classnames": "^2.5.1",
    "date-fns": "^2.30.0",
    "dotenv": "^16.6.1",
    "dotenv-safe": "^9.1.0",
    "expiry-map": "^2.0.0",
    "fathom-client": "^3.4.1",
    "got": "^14.4.8",
    "isomorphic-unfetch": "^3.1.0",
    "lodash.omit": "^4.5.0",
    "lqip-modern": "2.2.1",
    "next": "15.5.10",
    "notion-client": "7.8.2",
    "notion-types": "7.8.2",
    "notion-utils": "7.8.2",
    "p-map": "^5.3.0",
    "p-memoize": "^6.0.1",
    "posthog-js": "^1.255.0",
    "raf": "^3.4.1",
    "random": "^3.0.6",
    "react": "^18.3.1",
    "react-body-classname": "^1.3.1",
    "react-dom": "^18.3.1",
    "react-fluid-animation": "^1.0.1",
    "react-notion-x": "7.8.2",
    "react-tweet-embed": "^2.0.0",
    "react-use": "^17.6.0",
    "rss": "^1.2.2"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "15.5.10",
    "@trivago/prettier-plugin-sort-imports": "6.0.2",
    "@types/lodash.omit": "^4.5.6",
    "@types/node": "^20.17.57",
    "@types/react": "^18.3.18",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "cross-env": "^7.0.3",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^4.6.2",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.5.3",
    "typescript": "^5.8.3"
  },
  "overrides": {
    "cacheable-request": {
      "keyv": "npm:@keyvhq/core@~1.6.6"
    }
  }
}
